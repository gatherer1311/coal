#!/usr/bin/env sh
# Fast local gate: formatting. Skips gracefully if deps aren't installed.
# Bypass with `git commit --no-verify` (CI re-checks server-side regardless).
# Set SKIP_HOOKS=1 to skip all Coal hooks for a command.

[ "${SKIP_HOOKS:-}" = "1" ] && exit 0

if [ ! -x node_modules/.bin/prettier ]; then
  echo "pre-commit: prettier not installed (run 'npm install') — skipping format check." >&2
  exit 0
fi

if ! npm run --silent format:check; then
  echo "" >&2
  echo "pre-commit: formatting issues — fix with: npm run format" >&2
  exit 1
fi

exit 0
